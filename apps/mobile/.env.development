# Python FastAPI (`npm run ml:api` from repo root). Server uses --host 0.0.0.0 --port 8000.
# Expo Go: localhost/127.0.0.1 is rewritten to your Metro host (LAN IP or 10.0.2.2 on Android emulator).
# Leave localhost for dev; start script auto-resolves current LAN IP each run.
EXPO_PUBLIC_ML_API_URL=http://127.0.0.1:8000
